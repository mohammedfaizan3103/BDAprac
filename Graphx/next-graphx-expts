import org.apache.spark.graphx._
import org.apache.spark.rdd.RDD

// ----------------------------
// Step 1: Create Edges
// ----------------------------
val edges = sc.parallelize(Seq(
  Edge(1L, 2L, 1),
  Edge(2L, 3L, 1),
  Edge(3L, 1L, 1), // triangle
  Edge(3L, 4L, 1)  // extra edge
))

// ----------------------------
// Step 2: Create Graph
// ----------------------------
val graph = Graph.fromEdges(edges, 1)

// ----------------------------
// Step 3: Triangle Count
// ----------------------------
val triangles = graph.triangleCount().vertices

// ----------------------------
// Step 4: Print Output
// ----------------------------
triangles.collect.foreach {
  case (id, count) =>
    println(s"Node $id -> Triangles: $count")
}
