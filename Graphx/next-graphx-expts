import org.apache.spark.graphx._
import org.apache.spark.rdd.RDD

// ----------------------------
// Step 1: Airports (Vertices)
// ----------------------------
val vertices: RDD[(VertexId, String)] = sc.parallelize(Seq(
  (1L, "DEL"),
  (2L, "MUM"),
  (3L, "BLR"),
  (4L, "HYD"),
  (5L, "CHN"),
  (6L, "KOL")
))

// ----------------------------
// Step 2: Flight Routes (Edges)
// ----------------------------
val edges: RDD[Edge[Int]] = sc.parallelize(Seq(
  Edge(1L, 2L, 1), // DEL → MUM
  Edge(1L, 3L, 1), // DEL → BLR
  Edge(2L, 3L, 1), // MUM → BLR
  Edge(3L, 1L, 1), // BLR → DEL
  Edge(4L, 3L, 1), // HYD → BLR
  Edge(5L, 3L, 1), // CHN → BLR
  Edge(6L, 3L, 1), // KOL → BLR
  Edge(2L, 4L, 1), // MUM → HYD
  Edge(4L, 5L, 1), // HYD → CHN
  Edge(5L, 2L, 1)  // CHN → MUM
))

// ----------------------------
// Step 3: Create Graph
// ----------------------------
val graph = Graph(vertices, edges)

// ----------------------------
// Step 4: Run PageRank
// ----------------------------
val ranks = graph.pageRank(0.0001).vertices

// ----------------------------
// Step 5: Join with names
// ----------------------------
val result = vertices.join(ranks)

// ----------------------------
// Step 6: Print results
// ----------------------------
result.collect.foreach {
  case (id, (airport, rank)) =>
    println(s"Airport: $airport Rank: $rank")
}


